# Supabase — server-only credentials for the lead form (/api/lead).
# Where to find them: Supabase dashboard → Project Settings → API.
#   SUPABASE_URL              → "Project URL"
#   SUPABASE_SERVICE_ROLE_KEY → "service_role" secret key (NOT the anon key)
#
# Copy this file to `.env.local` and paste your real values there.
# `.env.local` is gitignored, so your keys never get committed.
# Do NOT prefix these with NEXT_PUBLIC_ — they must stay server-side.

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Resend — server-only API key for lead notification emails (/api/lead).
# Get it at resend.com → API Keys. The site works without it (emails are simply
# skipped); leads are still stored in Supabase.
RESEND_API_KEY=

# Lead-email addresses (optional — shown values are the built-in defaults).
# The FROM domain must be verified in Resend → Domains before real sends deliver.
LEAD_FROM_EMAIL=RumooEV <business@rumooev.com>
LEAD_NOTIFY_EMAIL=business@rumooev.com
LEAD_REPLY_TO=business@rumooev.com
